{
  "name": "chat-mood-meter",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:worker": "npm run dev -w apps/worker",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:root": "vitest run",
    "test:api": "npm test -w apps/api",
    "test:worker": "npm test -w apps/worker",
    "test:packages": "turbo run test --filter='./packages/*'",
    "db:migrate": "npm run db:migrate -w packages/db",
    "db:generate": "npm run db:generate -w packages/db",
    "lint": "turbo run lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@types/pg": "^8.18.0",
    "chart.js": "^4.5.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "react-chartjs-2": "^5.3.1",
    "react-router-dom": "^7.13.1"
  }
}
